# ============================================================
#  MarkFlow Base Image
#  Contains all system-level dependencies (apt packages).
#  Rebuild this only when system deps change -- not on every
#  code push. Saves ~25-30 min on HDD machines.
#
#  Build:  docker build -f Dockerfile.base -t markflow-base:latest .
# ============================================================
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Tesseract OCR
    tesseract-ocr \
    tesseract-ocr-eng \
    # Poppler (for pdf2image / pdftoppm)
    poppler-utils \
    # LibreOffice headless (minimal install for .doc -> .docx and PPTX charts)
    libreoffice-writer \
    libreoffice-impress \
    # WeasyPrint C library dependencies
    libpango-1.0-0 \
    libpangoft2-1.0-0 \
    libharfbuzz-subset0 \
    libcairo2 \
    libgdk-pixbuf-2.0-0 \
    # ImageMagick for EMF/WMF conversion
    imagemagick \
    # Ghostscript for EPS file conversion via Pillow (v0.22.14)
    ghostscript \
    # ExifTool for Adobe file metadata extraction
    libimage-exiftool-perl \
    # ffmpeg for keyframe extraction and media processing
    ffmpeg \
    # libmagic for MIME type detection (python-magic)
    libmagic1 \
    # pikepdf C library dependency (PDF password handling)
    libqpdf-dev \
    # Password cracking tools
    john \
    hashcat \
    hashcat-data \
    opencl-headers \
    ocl-icd-libopencl1 \
    clinfo \
    perl-base \
    # Archive extraction tools
    cabextract \
    unrar-free \
    p7zip-full \
    # Database file support (Access .mdb/.accdb)
    mdbtools \
    unixodbc-dev \
    odbc-mdbtools \
    # Network filesystem client tools (NFS/CIFS/SMB mount support)
    cifs-utils \
    nfs-common \
    smbclient \
    # curl for healthchecks
    curl \
    # Misc build tools
    gcc \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Pre-install heavy Python dependencies in base image (torch ~2.5GB, whisper ~1GB)
# These rarely change and are very slow to install on every rebuild.
#
# torch CUDA 12.1 build — lights up Whisper GPU transcription on NVIDIA hosts
# (Turing / CC 7.5 and newer, e.g. GTX 1660 Ti). On hosts without an NVIDIA
# GPU, torch.cuda.is_available() returns False and Whisper transparently
# falls back to CPU — same binary works everywhere. Host must have NVIDIA
# driver >= 525 and NVIDIA Container Toolkit installed to use the GPU.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cu121 \
    && pip install --no-cache-dir openai-whisper

# Database handler Python dependencies (dbfread for .dbf, pyodbc for Access ODBC)
# pysqlcipher3 omitted — requires libsqlcipher-dev + manual build; see docs/help/database-files.md
RUN pip install --no-cache-dir dbfread pyodbc

WORKDIR /app
