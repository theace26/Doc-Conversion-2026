# Host paths — set these per machine (not committed to git)
SOURCE_DIR=C:/Users/Xerxes/T86_Work/k_drv_test   # Input directory mounted as /mnt/source
OUTPUT_DIR=D:/Doc-Conv_Test                        # Output directory mounted as /mnt/output-repo
DRIVE_C=C:/                                        # Drive browser mount — C:
DRIVE_D=D:/                                        # Drive browser mount — D:

# Meilisearch
MEILI_HOST=http://localhost:7700          # http://meilisearch:7700 in Docker
MEILI_MASTER_KEY=                         # Leave empty for dev, set in production

# Bulk conversion
BULK_WORKER_COUNT=4                       # Number of parallel workers (1-16)
BULK_SOURCE_PATH=/mnt/source              # Default source path for new jobs
BULK_OUTPUT_PATH=/mnt/output-repo         # Default output path for new jobs

# Directory browser — drive letters mounted into the container (comma-separated, lowercase)
# Add a volume entry in docker-compose.yml for each letter listed here
MOUNTED_DRIVES=c,d

# Visual enrichment (v0.8.1)
# Vision uses the active LLM provider — configure via the Providers page.
# These control enrichment behavior, not provider selection.
VISION_ENRICHMENT_LEVEL=2        # 1=metadata | 2=+transcription | 3=+frame descriptions
VISION_FRAME_LIMIT=50            # max keyframes per video (1-200)
VISION_SAVE_KEYFRAMES=false      # save keyframe JPEGs to _markflow/frames/

# Existing
DB_PATH=markflow.db
OUTPUT_DIR=output
LOG_LEVEL=INFO
