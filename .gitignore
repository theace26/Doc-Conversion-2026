# SQLite database
markflow.db
data/
# v0.33.1: core/data/ holds shipped static data files (LLM rate table)
# that MUST be tracked. The blanket data/ rule above is for runtime
# data directories (SQLite, indexes); this negation re-includes the
# in-source data files.
!core/data/
!core/data/**
*.db

# Output and logs (runtime generated)
output/
logs/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
tests/fixtures/

# Environment
.env
.env.*
venv/
.venv/

# Input files (not committed)
input/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Host-specific worker capabilities (generated per-machine at deploy time)
hashcat-queue/worker_capabilities.json

# Overnight rebuild rollback sidecar (per-machine; tracks last-good image IDs)
Scripts/work/overnight/last-good.json

# docker-compose.override.yml is per-machine by Docker convention.
# Apple Silicon / no-GPU dev machines: copy docker-compose.apple-silicon.yml
# into place as docker-compose.override.yml locally. GPU hosts leave it absent
# so the base compose GPU reservation applies. See the sample file header.
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db

# Claude Code auto-memory should NEVER live in the project tree.
# The canonical path is ~/.claude/projects/<encoded-project>/memory/.
# If a stray `memory/` ever appears here it's an artifact from an earlier
# session writing to the wrong path — ignore it so it can't pollute
# `git status` or be committed by accident.
/memory/

# Local backup tarballs (markflow-db, meilisearch, qdrant, whisper-cache).
# Created by manual + scheduled volume backups. Several GB, never check in.
/backups/
.venv-test/
